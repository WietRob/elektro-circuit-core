    { "dinComponent": "DIN-P2-LAMP", "laborTarget": { "component": "LAB-P2-LAMP", "highlight": "component" }, "bidirectional": true }
  ],

  "logic": {
    "S1.closed": "states.k1_only",
    "S2.closed": "(states.k1_only AND K1-AUX-NO.closed) -> states.k1_and_k2",
    "K1-COIL.active": "S1.closed",
    "K1-COIL.ANKER.attracted": "K1-COIL.active",
    "K1-AUX-NO.closed": "K1-COIL.ANKER.attracted",
    "K2-COIL.active": "S2.closed AND K1-AUX-NO.closed",
    "K2-COIL.ANKER.attracted": "K2-COIL.active",
    "K2-AUX-NO.closed": "K2-COIL.ANKER.attracted",
    "P1.lit": "K1-COIL.active",
    "P2.lit": "K2-AUX-NO.closed"
  },

  "currentPaths": [
    {

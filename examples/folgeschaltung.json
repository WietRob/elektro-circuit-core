  "states": {
    "initial": {
      "id": "initial",
      "initial": true,
      "transitions": [
        { "trigger": "S1.pressed", "target": "k1_only", "actions": { "K1-COIL.active": true, "K1-AUX-NO.closed": true } }
      ],
      "expected": {
        "wireCurrentCount": 0,
        "activePaths": [],
        "componentStates": { "S1": "open", "K1-COIL": "inactive", "K1-AUX-NO": "open", "S2": "open", "K2-COIL": "inactive", "K2-AUX-NO": "open", "P1": "dark", "P2": "dark" }
      }
    },
    "k1_only": {
      "id": "k1_only",
      "initial": false,
      "transitions": [
        { "trigger": "S2.pressed", "target": "k1_and_k2", "actions": { "K2-COIL.active": true, "K2-AUX-NO.closed": true } }
      ],
      "expected": {
        "wireCurrentCount": 15,
        "activePaths": ["k1_control", "k1_load", "k1_enable"],
        "componentStates": { "S1": "open", "K1-COIL": "active", "K1-AUX-NO": "closed", "S2": "open", "K2-COIL": "inactive", "K2-AUX-NO": "open", "P1": "lit", "P2": "dark" }
      }
    },
    "k1_and_k2": {
      "id": "k1_and_k2",
      "initial": false,
      "transitions": [
        { "trigger": "S1.pressed", "target": "k2_only", "actions": { "K1-COIL.inactive": true, "K1-AUX-NO.open": true } }
      ],
      "expected": {
        "wireCurrentCount": 25,
        "activePaths": ["k1_control", "k1_load", "k1_enable", "k2_control", "k2_load"],
        "componentStates": { "S1": "open", "K1-COIL": "active", "K1-AUX-NO": "closed", "S2": "open", "K2-COIL": "active", "K2-AUX-NO": "closed", "P1": "lit", "P2": "lit" }
      }
    },
    "k2_only": {
      "id": "k2_only",
      "initial": false,
      "transitions": [
        { "trigger": "S2.pressed", "target": "initial", "actions": { "K2-COIL.inactive": true, "K2-AUX-NO.open": true } }
      ],
      "expected": {
        "wireCurrentCount": 10,
        "activePaths": ["k2_control", "k2_load"],
        "componentStates": { "S1": "open", "K1-COIL": "inactive", "K1-AUX-NO": "open", "S2": "open", "K2-COIL": "active", "K2-AUX-NO": "closed", "P1": "dark", "P2": "lit" }
      }
    }
  },

  "transferMappings": [
    { "dinComponent": "DIN-S1-BUTTON", "laborTarget": { "component": "LAB-S1-BUTTON", "highlight": "component" }, "bidirectional": true },
    { "dinComponent": "DIN-K1-COIL", "laborTarget": { "component": "LAB-K1-COIL", "highlight": "component" }, "bidirectional": true },
    { "dinComponent": "DIN-K1-AUX-NO", "laborTarget": { "component": "LAB-K1-AUX-NO", "highlight": "component" }, "bidirectional": true },
    { "dinComponent": "DIN-S2-BUTTON", "laborTarget": { "component": "LAB-S2-BUTTON", "highlight": "component" }, "bidirectional": true },
    { "dinComponent": "DIN-K2-COIL", "laborTarget": { "component": "LAB-K2-COIL", "highlight": "component" }, "bidirectional": true },
    { "dinComponent": "DIN-K2-AUX-NO", "laborTarget": { "component": "LAB-K2-AUX-NO", "highlight": "component" }, "bidirectional": true },
